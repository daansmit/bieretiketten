{
  "name": "bieretiketten",
  "version": "1.0.0",
  "description": "Bier etiketten beheer voor Sjef",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.1.7",
    "@tanstack/react-table": "^8.11.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "exceljs": "^4.4.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "41.2.2",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^5.3.3",
    "vite": "^7.3.2"
  },
  "build": {
    "appId": "com.daansmit.bieretiketten",
    "productName": "Bieretiketten",
    "files": [
      "out/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "daansmit",
        "repo": "bieretiketten"
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis", "zip"]
    }
  }
}
